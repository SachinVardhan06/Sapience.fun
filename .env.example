VITE_APP_NAME=sapience.fun

# Public URL of this Vite app in production (markets + app shell live here).
# Deploy to https://app.sapience.fun — override only if you use another host.
# VITE_APP_ORIGIN=https://app.sapience.fun

# Kalshi proxy (kalshi-proxy.cjs). Dev default is localhost:3001; in production set your deployed proxy URL.
# VITE_KALSHI_PROXY_URL=https://api.sapience.fun/api/kalshi/markets?limit=50&status=open

# GraphQL storage — use PostgreSQL in production (survives redeploys; enable backups in provider):
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# Local Postgres without SSL: DATABASE_SSL=0

# Or JSON on a persistent disk (no DATABASE_URL):
# SAPIENCE_DB_DIR=/data
# SAPIENCE_DB_PATH=/data/sapience-db.json

# GraphQL (Apollo in graphql-server.js). Production builds always use https://api.sapience.fun/ (site.js).
# Local dev default: http://localhost:4000/ — if port is busy, set:
# VITE_GQL_URL=http://localhost:4001/
# GQL_PORT=4000
# Introspection is on by default (required for Apollo Sandbox). To hide schema in production:
# GQL_DISABLE_INTROSPECTION=true
# Omit Mutation type entirely (read-only API; breaks app writes to GraphQL):
# GQL_DISABLE_MUTATIONS=true

# Kalshi proxy (kalshi-proxy.cjs) — optional; use literal \n for PEM line breaks in .env.local
# KALSHI_KEY_ID=
# KALSHI_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
